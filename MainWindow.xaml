<Window x:Class="GalloShowdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GalloShowdown" Height="520" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Window.Resources>

        <Style x:Key="SlideButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#e94560"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c73652"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartButtonStyle" TargetType="Button" BasedOn="{StaticResource SlideButtonStyle}">
            <Setter Property="Background" Value="#f5a623"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="30,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#d4891a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a4a80"/>
                              </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SignButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#f5e6c8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="#7a4a1e"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7a4a1e"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HousingBackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#562a00"/>
            <Setter Property="Foreground" Value="#f5e6c8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#7a4a1e"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7a4a1e"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- ── SLIDESHOW SCREEN ──────────────────────────────────── -->
        <Grid x:Name="SlideshowScreen">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="40,30,40,10"
                    Background="#16213e" CornerRadius="12">
                <Grid>
                    <Border x:Name="FadeOverlay"
                            Background="#16213e" CornerRadius="12"
                            Opacity="0" Panel.ZIndex="10"/>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="40">

                        <Rectangle x:Name="SlideImage"
                                   Width="200" Height="120"
                                   RadiusX="8" RadiusY="8"
                                   Margin="0,0,0,24"
                                   HorizontalAlignment="Center">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#e94560" Offset="0"/>
                                    <GradientStop Color="#0f3460" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <TextBlock x:Name="SlideIndicator"
                                   Foreground="#e94560" FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="SlideTitle"
                                   Foreground="White" FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="SlideDescription"
                                   Foreground="#b0b8d1" FontSize="15"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="500" LineHeight="24"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,10,40,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton" Grid.Column="0"
                        Content="← Previous"
                        Style="{StaticResource SlideButtonStyle}"
                        Click="PrevButton_Click"/>

                <ItemsControl x:Name="DotIndicators"
                              Grid.Column="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Button x:Name="NextButton" Grid.Column="2"
                        Content="Next →"
                        Style="{StaticResource SlideButtonStyle}"
                        Click="NextButton_Click"/>

                <Button x:Name="StartButton" Grid.Column="2"
                        Content="⚔ Start Game"
                        Style="{StaticResource StartButtonStyle}"
                        Visibility="Collapsed"
                        Click="StartButton_Click"/>
            </Grid>
        </Grid>

        <!-- ── NAVIGATION SCREEN ────────────────────────────────── -->
        <Grid x:Name="NavScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,28,0,16" HorizontalAlignment="Center">
                <TextBlock Text="⚔ GalloShowdown"
                           Foreground="#e94560" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Where will you go, champion?"
                           Foreground="#b0b8d1" FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <UniformGrid Grid.Row="1"
                         Rows="3" Columns="2"
                         Margin="80,0,80,36"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                <Button Content="Shop"     Tag="🛒" Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
                <Button Content="Training" Tag="🥊" Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
                <Button Content="Housing"  Tag="🏠" Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
                <Button Content="Battle"   Tag="⚔"  Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
                <Button Content="Forest"   Tag="🌲" Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
                <Button Content="Hatchery" Tag="🥚" Style="{StaticResource NavButtonStyle}" Margin="10" Click="NavButton_Click"/>
            </UniformGrid>
        </Grid>

        <!-- ── HOUSING SCENE ────────────────────────────────────── -->
        <Grid x:Name="HousingScreen" Visibility="Collapsed">

            <!-- Full-screen background -->
            <Image Source="Assets/Housing_Back.png"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

            <!-- Darkening overlay -->
            <Rectangle Fill="#55000000"/>

            <!-- Main layout: left sign | center | right sign -->
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: Previous sign button -->
                <Button Grid.Column="0" Grid.Row="0"
                        Content="◀&#x0a;Prev"
                        Style="{StaticResource SignButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                    <Button.Background>
                        <SolidColorBrush Color="#99562a"/>
                    </Button.Background>
                    <Button.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.5" ShadowDepth="4"/>
                    </Button.Effect>
                </Button>

                <!-- CENTER: Stats sign + rooster area -->
                <Grid Grid.Column="1" Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- Stats sign panel -->
                    <Border Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            MinWidth="320"
                            Margin="0,24,0,12"
                            Padding="24,16"
                            CornerRadius="10"
                            BorderThickness="4"
                            BorderBrush="#7a4a1e">
                        <Border.Background>
                            <SolidColorBrush Color="#562a00" Opacity="0.78"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="14" Opacity="0.6" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Rooster Stats"
                                       Foreground="#f5e6c8" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <TextBlock Text="❤  Health:"  Foreground="#f5e6c8" FontSize="13" Width="100"/>
                                <TextBlock Text="—"           Foreground="#f5a623" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <TextBlock Text="⚔  Attack:"  Foreground="#f5e6c8" FontSize="13" Width="100"/>
                                <TextBlock Text="—"           Foreground="#f5a623" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <TextBlock Text="🛡  Defense:" Foreground="#f5e6c8" FontSize="13" Width="100"/>
                                <TextBlock Text="—"           Foreground="#f5a623" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2">
                                <TextBlock Text="💨  Speed:"   Foreground="#f5e6c8" FontSize="13" Width="100"/>
                                <TextBlock Text="—"           Foreground="#f5a623" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Rooster display area (dirt circle placeholder) -->
                    <Border Grid.Row="1"
                            Width="220" Height="220"
                            CornerRadius="110"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderThickness="4"
                            BorderBrush="#7a5c2e">
                        <Border.Background>
                            <SolidColorBrush Color="#8b6340" Opacity="0.45"/>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Text="🐓"
                                   FontSize="64"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.35"/>
                    </Border>
                </Grid>

                <!-- RIGHT: Next sign button -->
                <Button Grid.Column="2" Grid.Row="0"
                        Content="Next&#x0a;▶"
                        Style="{StaticResource SignButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                    <Button.Background>
                        <SolidColorBrush Color="#99562a"/>
                    </Button.Background>
                    <Button.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.5" ShadowDepth="4"/>
                    </Button.Effect>
                </Button>

                <!-- Back to menu button -->
                <Button Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                        Content="← Back to Menu"
                        Style="{StaticResource HousingBackButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="10,8,0,10"
                        Click="HousingBack_Click"/>
            </Grid>
        </Grid>

    </Grid>
</Window>
